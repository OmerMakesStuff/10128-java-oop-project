{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run program",
      "type": "shell",
      "command": "./gradlew app:run -q --console=plain",
      "problemMatcher": [],
      "group": { "kind": "test", "isDefault": true }
    },
    // LEGACY - LINUX ONLY
    {
      "label": "LEGACY - Run program with preset data input",
      "type": "shell",
      "command": "(grep -h -v -E '^\\s*#' ${workspaceFolder}/test/inputs_data.txt; cat -) | ./gradlew app:run -q --console=plain --args=\"--no-load --no-save\"",
      "problemMatcher": [],
      "group": { "kind": "test" },
      "detail": "Not supported on Windows (CMD/Powershell)!"
    },
    {
      "label": "LEGACY - Run program with preset data & tests input",
      "type": "shell",
      "command": "(grep -h -v -E '^\\s*#' ${workspaceFolder}/test/inputs_data.txt ${workspaceFolder}/test/inputs_tests.txt; cat -) | ./gradlew app:run -q --console=plain --args=\"--no-load --no-save\"",
      "problemMatcher": [],
      "group": { "kind": "test" },
      "detail": "Not supported on Windows (CMD/Powershell)!"
    }
  ]
}
